{
    "editor.unicodeHighlight.nonBasicASCII": false,
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.autofetchPeriod": 600,
    "window.autoDetectColorScheme": true,
    "workbench.preferredDarkColorTheme": "One Dark Pro Night Flat",
    "workbench.preferredLightColorTheme": "GitHub Light Colorblind (Beta)",
    "workbench.editor.empty.hint": "hidden",
    "markdown-preview-enhanced.revealjsTheme": "none.css",
    "markdown-preview-enhanced.codeBlockTheme": "github.css",
    "markdown-preview-enhanced.previewTheme": "one-light.css",
    "editor.fontFamily": "'SUSE Mono', 'Zen Kaku Gothic New', Menlo, monospace",
    "editor.fontWeight": "400",
    "workbench.colorTheme": "One Dark Pro Night Flat",
    "markdown-preview-enhanced.enablePreviewZenMode": true,
    "workbench.fontAliasing": "antialiased",
    "liveServer.settings.donotShowInfoMsg": true,
    "workbench.colorCustomizations": {
        "editorIndentGuide.background": "#d5dfe5",
        "editorIndentGuide.activeBackground1": "#A3BE8C",
    },
    "liveServer.settings.donotVerifyTags": true,
    "editor.insertSpaces": true,
    "emmet.includeLanguages": {
        "javascript": "javascriptreact",
        "typescript": "typescriptreact",
    },
    "css.lint.unknownProperties": "ignore",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.singleQuote": true,
    "prettier.semi": true,
    "prettier.trailingComma": "all",
    "prettier.printWidth": 80,
    "prettier.tabWidth": 4,
    "prettier.arrowParens": "avoid",
    "prettier.bracketSpacing": true,
    "files.insertFinalNewline": true,
    "notebook.insertFinalNewline": true,
    "json.schemaDownload.enable": true,
    "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
    "editor.formatOnSave": false,
}
